# Copy to .env and fill in values. Never commit .env.

# Required for generate.ts (Google Places resolve from Maps URL)
GOOGLE_PLACES_API_KEY=

# Phase C: one $99 Payment Link from Stripe Dashboard (printed in outreach template)
STRIPE_PHASE_C_PAYMENT_LINK=

# Phase C: production site base URL (no trailing slash), e.g. https://your-app.vercel.app
ALBGE_VERCEL_SITE_BASE=

# Reserved for future / Phase A (not used by Phase C generate.ts)
ANTHROPIC_API_KEY=
STRIPE_SECRET_KEY=
